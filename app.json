{
  "expo": {
    "name": "提醒助手",
    "slug": "rehab-assistant",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rehab.assistant",
      "infoPlist": {
        "UIBackgroundModes": [
          "audio",
          "remote-notification"
        ],
        "NSPhotoLibraryUsageDescription": "需要访问相册以保存收款二维码",
        "NSPhotoLibraryAddUsageDescription": "需要保存收款二维码到相册",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.rehab.assistant",
      "versionCode": 5,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "SCHEDULE_EXACT_ALARM",
        "USE_FULL_SCREEN_INTENT",
        "WAKE_LOCK",
        "FOREGROUND_SERVICE"
      ]
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "color": "#4A90E2"
        }
      ],
      "expo-localization"
    ],
    "extra": {
      "eas": {
        "projectId": "01869539-dcee-4a6d-9a15-b4e1e3c2a968"
      }
    },
    "runtimeVersion": "1.0.2",
    "updates": {
      "url": "https://u.expo.dev/01869539-dcee-4a6d-9a15-b4e1e3c2a968"
    }
  }
}
