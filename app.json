{
  "expo": {
    "name": "康复助手",
    "slug": "rehab-assistant",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rehab.assistant",
      "infoPlist": {
        "UIBackgroundModes": [
          "remote-notification"
        ]
      }
    },
    "android": {
      "package": "com.rehab.assistant",
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "SCHEDULE_EXACT_ALARM"
      ]
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "color": "#4A90E2"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "01869539-dcee-4a6d-9a15-b4e1e3c2a968"
      }
    }
  }
}
